---
// ── Decorative SVG illustrations ─────────────────────────────────────────────
//
// Hand-drawn-feel botanical + writing-themed accents. Each one is an inline
// SVG using `currentColor` so the parent's `text-clay-*` class drives the ink.
// Default style is a thin ink outline at low opacity — they should never
// shout louder than the actual content.

interface Props {
  /** Which illustration to render. */
  type: "leaf" | "pen" | "feather" | "sprig" | "ink" | "twig" | "book";
  /** Extra Tailwind classes. Use to position, size, rotate, and tint. */
  class?: string;
  /** Floating animation duration in seconds (set to "none" to disable). */
  float?: number | "none";
}

const { type, class: className = "", float = 9 } = Astro.props;
const floatStyle =
  float === "none"
    ? ""
    : `animation: decor-float ${float}s ease-in-out infinite;`;
---

<span class={`decor inline-block ${className}`} style={floatStyle} aria-hidden="true">
  {type === "leaf" && (
    <svg viewBox="0 0 80 100" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M40 6 C 18 28, 8 56, 26 86 C 34 92, 46 92, 54 86 C 72 56, 62 28, 40 6 Z" />
      <path d="M40 12 L 40 90" stroke-width="1" />
      <path d="M40 28 L 24 38" stroke-width="0.8" />
      <path d="M40 28 L 56 38" stroke-width="0.8" />
      <path d="M40 48 L 22 60" stroke-width="0.8" />
      <path d="M40 48 L 58 60" stroke-width="0.8" />
      <path d="M40 68 L 28 76" stroke-width="0.8" />
      <path d="M40 68 L 52 76" stroke-width="0.8" />
    </svg>
  )}

  {type === "pen" && (
    <svg viewBox="0 0 90 90" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      {/* Body */}
      <path d="M68 14 L 80 26 L 36 70 L 18 76 L 24 58 Z" />
      {/* Nib slit */}
      <path d="M24 58 L 36 70" />
      {/* Cap line */}
      <path d="M60 22 L 72 34" />
      {/* Tail dot */}
      <circle cx="22" cy="74" r="1.2" fill="currentColor" />
    </svg>
  )}

  {type === "feather" && (
    <svg viewBox="0 0 60 120" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
      <path d="M30 8 C 12 24, 6 56, 14 82 L 30 70 L 46 82 C 54 56, 48 24, 30 8 Z" />
      <path d="M30 18 L 30 115" stroke-width="1" />
      <path d="M30 30 L 22 34" stroke-width="0.7" />
      <path d="M30 30 L 38 34" stroke-width="0.7" />
      <path d="M30 44 L 18 48" stroke-width="0.7" />
      <path d="M30 44 L 42 48" stroke-width="0.7" />
      <path d="M30 58 L 20 61" stroke-width="0.7" />
      <path d="M30 58 L 40 61" stroke-width="0.7" />
      <path d="M30 72 L 24 74" stroke-width="0.7" />
      <path d="M30 72 L 36 74" stroke-width="0.7" />
    </svg>
  )}

  {type === "sprig" && (
    <svg viewBox="0 0 100 60" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
      <path d="M6 50 C 30 40, 60 25, 94 12" />
      <path d="M28 38 C 22 30, 26 22, 36 24 C 32 32, 30 38, 28 38 Z" />
      <path d="M48 28 C 40 22, 42 12, 54 12 C 52 22, 50 28, 48 28 Z" />
      <path d="M70 20 C 66 12, 70 4, 80 6 C 76 14, 72 20, 70 20 Z" />
    </svg>
  )}

  {type === "ink" && (
    <svg viewBox="0 0 30 50" fill="currentColor">
      <path d="M15 4 C 5 18, 4 32, 15 46 C 26 32, 25 18, 15 4 Z" />
    </svg>
  )}

  {type === "twig" && (
    <svg viewBox="0 0 120 60" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M5 30 C 40 30, 70 30, 115 30" />
      <path d="M30 30 L 20 22" />
      <path d="M50 30 L 60 22" />
      <path d="M70 30 L 62 38" />
      <path d="M95 30 L 105 22" />
    </svg>
  )}

  {type === "book" && (
    <svg viewBox="0 0 80 70" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8 14 L 40 8 L 40 62 L 8 56 Z" />
      <path d="M72 14 L 40 8 L 40 62 L 72 56 Z" />
      <path d="M16 22 L 32 19" />
      <path d="M16 30 L 32 27" />
      <path d="M16 38 L 28 36" />
      <path d="M48 19 L 64 22" />
      <path d="M48 27 L 64 30" />
      <path d="M48 36 L 60 38" />
    </svg>
  )}
</span>

<style is:global>
  @keyframes decor-float {
    0%, 100% { transform: translate3d(0, 0, 0); }
    50%      { transform: translate3d(0, -10px, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .decor { animation: none !important; }
  }
</style>
