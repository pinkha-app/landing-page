---
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang).footer;
const year = new Date().getFullYear();
---

<footer class="px-6 py-12 border-t border-clay-100/50">
  <div class="mx-auto max-w-5xl">
    <div
      class="flex flex-col md:flex-row gap-6 items-center justify-between text-sm text-ink-500"
    >
      <div class="flex items-center gap-3">
        <img src="/icons/bowl.png" alt="" width="28" height="28" class="opacity-80" />
        <span class="font-serif italic">pinkha</span>
      </div>

      <nav class="flex flex-wrap gap-6 justify-center">
        <a href={localizePath("/privacy", lang)} class="hover:text-clay-500 transition-colors">{t.privacy}</a>
        <a href={localizePath("/terms", lang)} class="hover:text-clay-500 transition-colors">{t.terms}</a>
        <a
          href="https://github.com/pinkha-app"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-clay-500 transition-colors"
        >
          {t.github}
        </a>
        <a
          href="mailto:ybikouta.pro@icloud.com"
          class="hover:text-clay-500 transition-colors"
        >
          {t.contact}
        </a>
      </nav>
    </div>

    <div
      class="mt-8 pt-6 border-t border-clay-100/40 flex flex-col md:flex-row gap-3 items-center justify-between text-xs text-clay-400 font-mono"
    >
      <p>
        &copy; {year} Yannis Bikouta &middot; {t.rights}
      </p>
      <p>
        {t.sourceUnder}
        <a
          href="https://github.com/pinkha-app/pinkha/blob/master/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-clay-500 transition-colors"
        >
          MIT &middot; Apache 2.0
        </a>
      </p>
    </div>
  </div>
</footer>
