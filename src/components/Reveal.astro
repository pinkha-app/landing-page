---
// Wraps content with a fade-up reveal that fires once when the element first
// enters the viewport. IntersectionObserver-based — zero JS until scroll.

interface Props {
  /** Delay in ms before the reveal starts. Stagger items in a grid. */
  delay?: number;
  /** Tag to use as the wrapper. Defaults to <div>. */
  as?: string;
  class?: string;
}

const { delay = 0, as: Tag = "div", class: className = "" } = Astro.props;
---

<Tag class={`reveal ${className}`} style={`--reveal-delay: ${delay}ms;`}>
  <slot />
</Tag>

<style is:global>
  .reveal {
    opacity: 0;
    transform: translate3d(0, 28px, 0);
    transition:
      opacity 900ms cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms),
      transform 900ms cubic-bezier(0.16, 1, 0.3, 1) var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  .reveal.in-view {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      transition: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // Single shared observer for the whole page.
  const io = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          io.unobserve(entry.target);
        }
      }
    },
    { threshold: 0.12, rootMargin: "0px 0px -80px 0px" }
  );

  const init = () => {
    document.querySelectorAll(".reveal:not(.in-view)").forEach((el) => io.observe(el));
  };

  // Hook up immediately on first load and after any View Transition.
  init();
  document.addEventListener("astro:page-load", init);
</script>
