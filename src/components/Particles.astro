---
// Ambient floating ink specks that drift across the viewport. Pure CSS,
// no JS, ~12 particles total. Positioned fixed so they live behind every
// section — the landing always has a faint sense of movement.

const N = 14;
const particles = Array.from({ length: N }).map((_, i) => ({
  left:     Math.round((i * 73) % 100),         // pseudo-random horizontal start
  size:     2 + ((i * 37) % 4),                 // 2–5 px
  duration: 28 + ((i * 11) % 22),               // 28–50 s
  delay:    -(i * 4),                            // negative so all are mid-flight at load
  opacity:  0.18 + ((i * 13) % 18) / 100,       // 0.18–0.36
}));
---

<div class="particles" aria-hidden="true">
  {
    particles.map((p) => (
      <span
        class="particle"
        style={`
          left: ${p.left}%;
          width: ${p.size}px;
          height: ${p.size}px;
          opacity: ${p.opacity};
          animation-duration: ${p.duration}s;
          animation-delay: ${p.delay}s;
        `}
      />
    ))
  }
</div>

<style>
  .particles {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    bottom: -10vh;
    background: var(--color-clay-400);
    border-radius: 50%;
    animation-name: drift;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
    filter: blur(0.5px);
  }
  @keyframes drift {
    0%   { transform: translate3d(0, 0, 0) scale(1);   opacity: 0; }
    10%  { opacity: var(--p-opacity, 0.3); }
    50%  { transform: translate3d(20px, -55vh, 0) scale(1.15); }
    90%  { opacity: var(--p-opacity, 0.3); }
    100% { transform: translate3d(-30px, -120vh, 0) scale(0.8); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .particles { display: none; }
  }
</style>
