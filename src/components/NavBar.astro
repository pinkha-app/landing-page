---
import { getLangFromUrl, useTranslations, localizePath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang).nav;
const tLang = useTranslations(lang).langSwitch;
const homeHref = localizePath("/", lang);

// Equivalents of the current page in each locale, for the switcher.
const altEn = localizePath(Astro.url.pathname, "en");
const altFr = localizePath(Astro.url.pathname, "fr");

const links = [
  {
    key: "features" as const,
    href: "#features",
    icon: '<path d="M12 3v3M12 18v3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M3 12h3M18 12h3M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.8"/>',
  },
  {
    key: "screens" as const,
    href: "#screens",
    icon: '<rect x="6" y="3" width="12" height="18" rx="3" stroke="currentColor" stroke-width="1.8"/><line x1="10.5" y1="18" x2="13.5" y2="18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>',
  },
  {
    key: "source" as const,
    href: "#source",
    icon: '<path d="M8 6 3 12l5 6M16 6l5 6-5 6M14 4l-4 16" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
];
const testflightUrl =
  Astro.props.testflightUrl ??
  "https://testflight.apple.com/join/hGhCJJBM";
---

<header class="nav-shell fixed left-1/2 -translate-x-1/2 z-50 w-[min(720px,calc(100%-1.25rem))]">
  <nav class="liquid-glass" aria-label="Primary">
    <!-- Layer 1 : refracted backdrop (the "lens" content underneath the glass) -->
    <span aria-hidden="true" class="lg-backdrop"></span>
    <!-- Layer 2 : tinted glass body -->
    <span aria-hidden="true" class="lg-tint"></span>
    <!-- Layer 3 : top specular highlight -->
    <span aria-hidden="true" class="lg-specular"></span>
    <!-- Layer 4 : bottom inner shadow -->
    <span aria-hidden="true" class="lg-depth"></span>

    <div class="lg-content">
      <a href={homeHref} class="nav-brand" aria-label={t.home}>
        <img src="/icons/bowl.png" alt="Pinkha" width="28" height="28" />
      </a>

      <div class="nav-links">
        {
          links.map((l) => (
            <a href={l.href} class="nav-link">
              <span class="nav-link-bubble" aria-hidden="true" />
              <svg viewBox="0 0 24 24" fill="none" width="16" height="16" class="nav-icon" set:html={l.icon} />
              <span class="nav-label">{t[l.key]}</span>
            </a>
          ))
        }
      </div>

      <div class="nav-lang" role="group" aria-label={tLang.label}>
        <a
          href={altEn}
          data-lang-set="en"
          class:list={["nav-lang-opt", { "is-active": lang === "en" }]}
          aria-current={lang === "en" ? "true" : undefined}
        >EN</a>
        <span class="nav-lang-sep" aria-hidden="true">/</span>
        <a
          href={altFr}
          data-lang-set="fr"
          class:list={["nav-lang-opt", { "is-active": lang === "fr" }]}
          aria-current={lang === "fr" ? "true" : undefined}
        >FR</a>
      </div>

      <a href={testflightUrl} target="_blank" rel="noopener noreferrer" class="nav-cta">
        <span>{t.cta}</span>
        <svg viewBox="0 0 24 24" fill="none" width="14" height="14">
          <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  /* ── The pill shell ────────────────────────────────────────────── */
  .liquid-glass {
    position: relative;
    border-radius: 9999px;
    isolation: isolate;
    /* Clip the displaced backdrop to the pill shape — otherwise the
       feDisplacementMap pushes pixels outside the pill silhouette. */
    overflow: hidden;
  }
  /* The drop shadow lives on a wrapper so it doesn't get clipped by overflow. */
  .nav-shell {
    filter: drop-shadow(0 1px 1px rgba(126, 73, 35, 0.04))
            drop-shadow(0 8px 24px rgba(126, 73, 35, 0.18))
            drop-shadow(0 24px 48px rgba(126, 73, 35, 0.10));
  }

  /* Layer 1 : the frosted glass backdrop. Standard backdrop-filter — works
     identically in Safari, Chrome and Firefox. Heavy blur so content behind
     never competes with the nav labels. */
  .lg-backdrop {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    backdrop-filter: blur(36px) saturate(180%) brightness(108%);
    -webkit-backdrop-filter: blur(36px) saturate(180%) brightness(108%);
    z-index: -3;
  }

  /* Layer 2 : the glass tint — opaque enough that nav text never has to
     fight with what's behind the bar. iOS 26 system bars sit around 50–65 %
     opacity; we mirror that with a warm cream gradient. */
  .lg-tint {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 250, 244, 0.62) 0%,
      rgba(250, 246, 240, 0.50) 50%,
      rgba(248, 240, 230, 0.58) 100%
    );
    z-index: -2;
  }

  /* Layer 3 : specular highlight — the wet-glass reflection along the top arc */
  .lg-specular {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(ellipse 70% 100% at 50% -20%,
        rgba(255, 255, 255, 0.7) 0%,
        rgba(255, 255, 255, 0) 50%);
    mix-blend-mode: screen;
    z-index: -1;
  }

  /* Layer 4 : the inner depth shadow at the bottom — gives glass thickness */
  .lg-depth {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow:
      inset 0 1.5px 0 0 rgba(255, 255, 255, 0.65),  /* top edge highlight */
      inset 0 -1px 0 0 rgba(126, 73, 35, 0.12),     /* bottom edge */
      inset 1px 0 0 0 rgba(255, 255, 255, 0.35),    /* left edge */
      inset -1px 0 0 0 rgba(255, 255, 255, 0.35);   /* right edge */
    pointer-events: none;
  }

  /* ── Content row ─────────────────────────────────────────────── */
  .lg-content {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.375rem;
    z-index: 1;
  }

  /* ── Brand ──────────────────────────────────────────────────── */
  .nav-brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    color: var(--color-ink-900);
  }
  .nav-brand img {
    height: 28px;
    width: 28px;
    transition: transform 300ms ease;
  }
  .nav-brand:hover img { transform: rotate(-8deg) scale(1.08); }

  /* ── Position: top on desktop, bottom on phone (iOS Safari pattern) ── */
  .nav-shell {
    top: 0.75rem;
  }
  @media (max-width: 767px) {
    .nav-shell {
      top: auto;
      /* Respect the home-indicator safe area on modern iPhones. */
      bottom: calc(0.75rem + env(safe-area-inset-bottom, 0px));
    }
  }

  /* ── Links cluster ──────────────────────────────────────────── */
  .nav-links {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    margin-left: 0.25rem;
  }
  /* Hide labels on phone to keep the bar compact (icon-only). */
  @media (max-width: 767px) {
    .nav-links { margin-left: 0.125rem; }
    .nav-label { display: none; }
    .nav-link  { padding: 0.5rem 0.625rem; }
  }

  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    border-radius: 9999px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-ink-900);
    /* Subtle text shadow improves readability when the bar passes over
       text or photos with mid-range luminance. */
    text-shadow: 0 1px 0 rgba(255, 245, 230, 0.6);
    transition: color 220ms ease;
    isolation: isolate;
  }
  .nav-link:hover { color: var(--color-clay-600); }

  /* The floating "tab bubble" behind the link — iOS 26 signature */
  .nav-link-bubble {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.55) 0%,
      rgba(255, 255, 255, 0.18) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      inset 0 -1px 0 rgba(126, 73, 35, 0.08),
      0 1px 3px rgba(126, 73, 35, 0.10);
    opacity: 0;
    transform: scale(0.86);
    transition:
      opacity 280ms cubic-bezier(0.34, 1.56, 0.64, 1),
      transform 280ms cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: -1;
  }
  .nav-link:hover .nav-link-bubble {
    opacity: 1;
    transform: scale(1);
  }
  .nav-icon { color: currentColor; opacity: 0.85; }

  /* ── Language switcher ──────────────────────────────────────── */
  .nav-lang {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 12.5px;
    font-weight: 600;
    padding: 0 0.15rem;
  }
  .nav-lang-opt {
    color: var(--color-clay-400);
    text-shadow: 0 1px 0 rgba(255, 245, 230, 0.6);
    transition: color 180ms ease;
    padding: 0.25rem 0.1rem;
  }
  .nav-lang-opt:hover { color: var(--color-clay-600); }
  .nav-lang-opt.is-active { color: var(--color-ink-900); }
  .nav-lang-sep { color: var(--color-clay-300); }

  /* ── CTA — tinted Liquid Glass with terracotta body ─────────── */
  .nav-cta {
    margin-left: 0.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border-radius: 9999px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--color-cream-50);
    background: linear-gradient(
      180deg,
      var(--color-clay-400) 0%,
      var(--color-clay-500) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.4),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 4px 12px -2px rgba(126, 73, 35, 0.35);
    transition: transform 180ms ease, box-shadow 180ms ease;
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12),
      0 8px 18px -2px rgba(126, 73, 35, 0.45);
  }
  .nav-cta:active { transform: translateY(0); }
</style>

<script>
  // When the visitor picks a language, remember it in a cookie so the edge
  // middleware stops auto-redirecting against their manual choice. Delegated
  // + guarded so it survives view transitions without double-binding.
  if (!(window as any).__pinkhaLangBound) {
    (window as any).__pinkhaLangBound = true;
    document.addEventListener("click", (e) => {
      const el = (e.target as Element)?.closest?.("[data-lang-set]");
      if (!el) return;
      const choice = el.getAttribute("data-lang-set");
      document.cookie = `pinkha_lang=${choice}; path=/; max-age=31536000; samesite=lax`;
    });
  }
</script>

