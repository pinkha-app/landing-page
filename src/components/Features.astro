---
import Decor from "./Decor.astro";
import Reveal from "./Reveal.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang).features;
const features = t.items;
---

<section id="features" class="relative isolate px-6 py-24 md:py-32 overflow-hidden">
  <!-- A scattered branch & ink drop in the corners. -->
  <div aria-hidden="true" class="hidden md:block pointer-events-none absolute inset-0 -z-[5]">
    <Decor type="sprig"   class="absolute top-12 right-[5%] w-32 text-clay-300/75 rotate-[12deg]" float={12} />
    <Decor type="ink"     class="absolute top-32 left-[7%]  w-3  text-clay-400/60"                float={9}  />
  </div>

  <div class="mx-auto max-w-6xl">
    <Reveal>
      <div class="text-center mb-20">
        <!-- Tiny twig divider above the eyebrow -->
        <div class="flex justify-center mb-6">
          <Decor type="twig" class="w-16 text-clay-300/90" float="none" />
        </div>
        <p class="font-mono uppercase tracking-[0.25em] text-clay-400 text-xs mb-4">
          {t.eyebrow}
        </p>
        <h2 class="font-serif text-4xl md:text-6xl font-medium text-ink-900 leading-[1.05] max-w-3xl mx-auto">
          {t.title1}<br />
          <span class="italic text-clay-500">{t.title2}</span>
        </h2>
      </div>
    </Reveal>

    <div class="grid md:grid-cols-3 gap-5 md:gap-8">
      {
        features.map((f, i) => (
          <Reveal delay={i * 120}>
          <article class="group relative p-8 md:p-10 rounded-3xl bg-cream-50 border border-clay-200/30 hover:border-clay-300/50 transition-all hover:-translate-y-1 hover:shadow-[0_12px_40px_-12px_rgba(126,73,35,0.18)]">
            <!-- decorative number -->
            <span class="absolute top-6 right-7 font-serif italic text-clay-200 text-xl select-none">
              {String(i + 1).padStart(2, "0")}
            </span>

            <!-- glyph stamp -->
            <div class="mb-6 inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-clay-50 border border-clay-200/40">
              {f.glyph === "leaf" && (
                <svg viewBox="0 0 24 24" fill="none" width="24" height="24" stroke="currentColor" stroke-width="1.5" class="text-clay-500">
                  <path d="M4 20s.5-9 8-13c5-2.7 9-2 9-2s.7 4-2 9c-4 7.5-13 8-13 8z"/>
                  <path d="M5 19c4-5 8-7 14-12"/>
                </svg>
              )}
              {f.glyph === "book" && (
                <svg viewBox="0 0 24 24" fill="none" width="24" height="24" stroke="currentColor" stroke-width="1.5" class="text-clay-500">
                  <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v18H6.5A2.5 2.5 0 0 1 4 17.5v-13z"/>
                  <path d="M4 17.5A2.5 2.5 0 0 1 6.5 15H20"/>
                </svg>
              )}
              {f.glyph === "shelf" && (
                <svg viewBox="0 0 24 24" fill="none" width="24" height="24" stroke="currentColor" stroke-width="1.5" class="text-clay-500">
                  <rect x="3" y="4" width="4" height="12"/>
                  <rect x="9" y="7" width="4" height="9"/>
                  <rect x="15" y="2" width="4" height="14"/>
                  <line x1="2" y1="17" x2="22" y2="17"/>
                </svg>
              )}
            </div>

            <p class="font-serif italic text-clay-400 text-sm lowercase tracking-wide mb-2">
              {f.glyphLabel}.
            </p>
            <h3 class="font-serif text-2xl md:text-3xl font-medium text-ink-900 mb-3">
              {f.title}
            </h3>
            <p class="text-ink-500 leading-relaxed">{f.body}</p>
          </article>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
