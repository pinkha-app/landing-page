---
import Decor from "./Decor.astro";
import Reveal from "./Reveal.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang).manifesto;
const tenets = t.tenets;
---

<section class="relative isolate px-6 py-28 md:py-40 overflow-hidden">
  <div aria-hidden="true" class="hidden md:block pointer-events-none absolute inset-0 -z-[5]">
    <Decor type="ink"     class="absolute top-16  left-[12%] w-3  text-clay-400/60"               float={9}  />
    <Decor type="feather" class="absolute top-32  right-[8%] w-12 text-clay-300/70 rotate-[22deg]" float={11} />
    <Decor type="ink"     class="absolute bottom-20 left-[16%] w-4 text-clay-400/55"              float={8}  />
  </div>

  <div class="mx-auto max-w-3xl text-center">
    <Reveal>
      <div class="flex justify-center mb-6">
        <Decor type="twig" class="w-16 text-clay-300/90" float="none" />
      </div>
      <p class="font-mono uppercase tracking-[0.25em] text-clay-400 text-xs mb-4">
        {t.eyebrow}
      </p>
      <h2
        class="font-serif text-4xl md:text-6xl font-medium text-ink-900 leading-[1.05] [text-wrap:balance]"
      >
        {t.title1}
        <span class="italic text-clay-500 block">{t.title2}</span>
      </h2>
      <p
        class="mt-8 text-lg md:text-xl text-ink-500 leading-relaxed font-serif italic [text-wrap:balance]"
      >
        {t.intro}
      </p>
    </Reveal>

    <div class="mt-16 space-y-10 md:space-y-12 text-left">
      {
        tenets.map((tenet, i) => (
          <Reveal delay={i * 120}>
            <article class="grid grid-cols-[auto_1fr] gap-6 md:gap-8 items-start">
              <div class="flex items-center justify-center w-14 h-14 rounded-full bg-cream-50 border border-clay-200/40 text-clay-500 shrink-0">
                <Decor type={tenet.glyph as "leaf" | "book" | "feather"} class="w-7" float="none" />
              </div>
              <p class="font-serif text-xl md:text-2xl text-ink-700 leading-snug [text-wrap:pretty]">
                {tenet.line}
              </p>
            </article>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
