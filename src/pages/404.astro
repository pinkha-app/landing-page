---
import Base from "../layouts/Base.astro";
import Footer from "../components/Footer.astro";
import Particles from "../components/Particles.astro";
---

<Base
  title="Not found — Pinkha"
  description="That leaf has fallen. Head back to the library."
>
  <Particles />
  <section class="relative isolate min-h-[calc(100vh-12rem)] flex items-center justify-center px-6 overflow-hidden">
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[680px] h-[680px] rounded-full bg-clay-100/40 blur-3xl"></div>
    </div>

    <div class="text-center max-w-xl">
      <div class="relative inline-block mb-10">
        <div aria-hidden="true" class="absolute inset-0 -z-10 blur-2xl bg-clay-300/40 rounded-full scale-110"></div>
        <img
          src="/icons/bowl.png"
          alt="An empty bowl."
          width="160"
          height="160"
          class="h-24 w-24 md:h-32 md:w-32 select-none drop-shadow-[0_24px_40px_rgba(126,73,35,0.25)] rotate-[-8deg]"
        />
      </div>

      <p class="font-mono text-xs uppercase tracking-[0.25em] text-clay-400 mb-4">
        404 &middot; not found
      </p>
      <h1 class="font-serif text-5xl md:text-6xl font-medium text-ink-900 leading-[1.05] [text-wrap:balance]">
        That leaf has
        <span class="italic text-clay-500">fallen.</span>
      </h1>
      <p class="mt-6 text-lg text-ink-500 leading-relaxed font-serif">
        The page you were looking for is no longer on the shelf.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 mt-8 rounded-full bg-ink-900 px-7 py-3.5 text-cream-50 font-medium hover:bg-clay-500 transition-colors"
      >
        <span aria-hidden="true">←</span> Back to the library
      </a>
    </div>
  </section>
  <Footer />
</Base>
