---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import Manifesto from "../components/Manifesto.astro";
import Screenshots from "../components/Screenshots.astro";
import OpenSource from "../components/OpenSource.astro";
import Footer from "../components/Footer.astro";
import Particles from "../components/Particles.astro";
import { ui } from "../i18n/ui";

const meta = ui.en.meta;
---

<Base title={meta.homeTitle} description={meta.homeDescription}>
  <Particles />
  <Hero />
  <Features />
  <Manifesto />
  <Screenshots />
  <OpenSource />
  <Footer />
</Base>
