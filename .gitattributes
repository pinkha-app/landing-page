# Auto-normalise text files: LF in repo, native on checkout.
* text=auto eol=lf

# Languages / formats — explicit so the auto-detection never gets it wrong.
*.astro    text eol=lf
*.css      text eol=lf
*.html     text eol=lf
*.js       text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.mjs      text eol=lf
*.svg      text eol=lf
*.ts       text eol=lf
*.tsx      text eol=lf
*.txt      text eol=lf
*.xml      text eol=lf
*.yaml     text eol=lf
*.yml      text eol=lf

# Lock files — text but never re-normalise (don't churn lockfiles).
package.json     text eol=lf
pnpm-lock.yaml   text eol=lf -text

# Binary assets — never touched by Git's line-ending logic.
*.gif       binary
*.ico       binary
*.jpg       binary
*.jpeg      binary
*.mp3       binary
*.mp4       binary
*.pdf       binary
*.png       binary
*.webm      binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.zip       binary
